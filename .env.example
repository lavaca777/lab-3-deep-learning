# Ruta a la carpeta que contiene las imagenes *.jpg de UTKFace.
UTKFACE_DIR=/ruta/a/UTKFace

# Directorio donde se guardan checkpoints, reportes, graficos y particiones.
ARTIFACTS_DIR=artifacts

# Checkpoint usado por la aplicacion Streamlit.
CNN_CHECKPOINT=artifacts/checkpoints/cnn_base/best_model.pt

# Hiperparametros comunes para comparaciones reproducibles.
SEED=42
IMAGE_SIZE=224
BATCH_SIZE=32
EPOCHS=10
LEARNING_RATE=0.001
WEIGHT_DECAY=0.0001
LAMBDA_AGE=0.01
NUM_WORKERS=0

# Dejar en 0 para usar todas las imagenes. Es util usar un valor pequeno al depurar.
MAX_IMAGES=0

# auto, cpu, cuda o mps.
DEVICE=auto
